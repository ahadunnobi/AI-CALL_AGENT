# ─────────────────────────────────────────────────────────────────────────────
#  AI-CALL_AGENT — Environment Configuration
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
LLM_HISTORY_TURNS=6

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# Options: "vosk" | "whisper"
STT_ENGINE=vosk
VOSK_MODEL_PATH=./ai-brain/models/vosk-model-small-en-us-0.15
WHIPSER_MODEL=base

# ── Voice Synthesis ───────────────────────────────────────────────────────────
# Options: "pyttsx3" | "coqui"
TTS_ENGINE=pyttsx3
VOICE_SAMPLE_PATH=./voice-clone/my_voice.wav
PYTTSX3_RATE=160

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./memory/caller_memory.db

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── SIP / Telephony ───────────────────────────────────────────────────────────
SIP_URI=
SIP_PASSWORD=
SIP_REGISTRAR=
SIP_DISPLAY_NAME=Ahad's AI Assistant

# ── Agent Persona ─────────────────────────────────────────────────────────────
OWNER_NAME=Ahad
AGENT_PERSONA=You are a professional personal assistant for {owner}. Answer concisely.

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
