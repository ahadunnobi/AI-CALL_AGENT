# ─────────────────────────────────────────────────────────────────────────────
#  AI-CALL_AGENT — Environment Configuration
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Ollama / LLM ──────────────────────────────────────────────────────────────
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=mistral
# Max conversation turns kept in memory per call session
LLM_HISTORY_TURNS=6

# ── Speech-to-Text ────────────────────────────────────────────────────────────
# Options: "vosk" | "whisper"
STT_ENGINE=vosk
# Path to the downloaded Vosk model folder (e.g. vosk-model-small-en-us-0.15)
VOSK_MODEL_PATH=./ai-brain/models/vosk-model-small-en-us-0.15
# Whisper model size (tiny | base | small | medium | large) — only if STT_ENGINE=whisper
WHISPER_MODEL=base

# ── Voice Synthesis ───────────────────────────────────────────────────────────
# Options: "pyttsx3" | "coqui" | "elevenlabs"
TTS_ENGINE=elevenlabs
# Path to your recorded voice sample .wav file (used by Coqui for voice cloning)
VOICE_SAMPLE_PATH=./voice-clone/my_voice.wav
# Speech rate for pyttsx3 (words per minute)
PYTTSX3_RATE=160
# ElevenLabs (Required if TTS_ENGINE=elevenlabs)
ELEVENLABS_API_KEY=
ELEVENLABS_VOICE_ID=pNInz6obpg8nEByWQX7d

# ── Database ──────────────────────────────────────────────────────────────────
DB_PATH=./memory/caller_memory.db

# ── FastAPI Server ────────────────────────────────────────────────────────────
API_HOST=127.0.0.1
API_PORT=8000

# ── SIP / Telephony ───────────────────────────────────────────────────────────
# Your SIP account credentials (from your SIP provider, e.g. linphone, sip.us)
SIP_URI=sip:yourusername@sip.example.com
SIP_PASSWORD=your_sip_password
SIP_REGISTRAR=wss://sip.example.com:7443
# Display name callers will see
SIP_DISPLAY_NAME=My AI Assistant

# ── Agent Persona ─────────────────────────────────────────────────────────────
# Your real name — the agent will present itself on your behalf
OWNER_NAME=Your Name
AGENT_PERSONA=You are a professional personal assistant for {owner}. You answer calls on their behalf, take messages, provide information, and assist callers politely.

# ── Logging ───────────────────────────────────────────────────────────────────
# Options: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO
LOG_FILE=./logs/agent.log
